FROM python:3.12-alpine

RUN apk add --no-cache curl && \
    addgroup -S appgroup && adduser -S appuser -G appgroup

COPY langgraph-service/pyproject.toml /tmp/
RUN pip install --no-cache-dir /tmp/

WORKDIR /workspace/langgraph-service
USER appuser
CMD ["uvicorn", "src.main:app", "--reload", "--host", "0.0.0.0", "--port", "5050"]
